{
	"name": "obsidian-llm-auto-title",
	"version": "0.2.4",
	"description": "Obsidian plugin: generate note titles via a local LLM (LMStudio by default, any OpenAI-compat server).",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"lmstudio",
		"title",
		"timestamp"
	],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@eslint/json": "0.14.0",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint": "^9.30.0",
		"eslint-plugin-obsidianmd": "0.4.1",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
